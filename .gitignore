# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# QA evidence (never commit)
browser-qa/

# Drizzle: migrations and the meta journal ARE committed (source of truth).
# Only ignore local query cache/logs.
drizzle/*.log

# Agent session/workspace artifacts (never commit)
.zcode/


# iOS build artifacts
ios/Kairo/.build/
ios/Kairo/.swiftpm/
ios/Kairo/Package.resolved
live-hero.png
live-night.png
